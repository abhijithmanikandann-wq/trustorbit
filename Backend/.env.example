NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://trustorbit:trustorbit_dev_password@localhost:5433/trustorbit
POSTGRES_DB=trustorbit
POSTGRES_USER=trustorbit
POSTGRES_PASSWORD=trustorbit_dev_password
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK=testnet
SOROBAN_ESCROW_CONTRACT_ID=replace-with-your-soroban-escrow-contract-id
# Override these only when your deployed ABI uses different method names.
SOROBAN_DEPOSIT_METHOD=deposit
SOROBAN_RELEASE_METHOD=release
SOROBAN_REFUND_METHOD=refund
# JSON arrays. Defaults are deposit:["payer","payee","amount_stroops","contract_id"],
# release:["payee","amount_stroops","contract_id"], refund:["payer","amount_stroops","contract_id"].
# Entries may be names or descriptors, e.g. {"name":"amount_stroops","type":"i128"}.
# SOROBAN_DEPOSIT_ARGUMENTS=["payer","payee",{"name":"amount_stroops","type":"i128"},"contract_id"]
